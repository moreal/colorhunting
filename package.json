{
  "name": "colorhunting",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:pages": "tsc -b && vite build --mode github-pages",
    "format": "oxfmt --write index.html package.json tsconfig.json tsconfig.app.json tsconfig.node.json vite.config.ts \".storybook/**/*.{ts,tsx}\" \"src/**/*.{ts,tsx,css}\"",
    "format:check": "oxfmt --check index.html package.json tsconfig.json tsconfig.app.json tsconfig.node.json vite.config.ts \".storybook/**/*.{ts,tsx}\" \"src/**/*.{ts,tsx,css}\"",
    "lint": "oxlint --deny-warnings --vitest-plugin .",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "motion": "^12.38.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@storybook/react-vite": "10.3.5",
    "@testing-library/dom": "^10.0.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^27.0.0",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "storybook": "10.3.5",
    "typescript": "^5.0.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.5"
  },
  "packageManager": "yarn@4.14.1"
}
